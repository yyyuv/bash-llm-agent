// doit v5 — clarifications + richer interactions (Phase 5)
// Builds on v4 (multi-turn history replay, native adapter). Two new things:
//   1. a third tool, ask_user(question, options?), and
//   2. a WITHIN-TURN loop: ask_user does NOT end the turn — the controller
//      prints the question, blocks on input(), feeds the reply back as the
//      tool result, and re-calls the LPU. So @T.I now really ranges over
//      several steps in one turn (Class 9's step-within-turn @T.I), where in
//      v1–v4 it was effectively a single step. That loop is the visual diff
//      to place next to v4 in the report.
//
// Richer interactions (Section 7) need NO new element: "how do I X" is just
// answer, and "modify it" / "execute it" resolve through the v4 history
// replay above (the model lifts a command out of its own past answer). So
// this spec is v4 + the ask_user branch, nothing else.
//
// NAMESPACE CONVENTION (applies to all specs, per the ACDL reference):
//   namespaces encode WHO PRODUCED the data — env = the user/world,
//   resp = the LPU, sys = the controller's own records — and never change
//   with age: a tool call the model made last turn is resp.tool_call[@t.i],
//   the same as this turn's resp.tool_call[@T.i]. Roles (U:/A:/T:) encode
//   only how content is packaged for the API and MAY differ between the
//   history replay (plain chat messages — no live tool_call_id survives
//   across invocations) and the current turn (native tool results).
//
// Design notes:
//   - Non-annoyance is enforced in TWO places: the prompt policy (ask only
//     if a wrong guess is destructive OR interpretations differ materially),
//     AND a hard structural cap MAX_CLARIFICATIONS=2 in the controller —
//     past it the model is told to commit to its best guess (belt & braces).
//   - Unanswered clarification (DECISION 8, option a): empty input / EOF →
//     tell the model "no answer, use your stated default". Safety is NOT
//     weakened by proceeding: if the default yields a destructive command,
//     the run_command confirmation below still demands an explicit "y" — so
//     "destructive → abort, read-only → default" falls out of the EXISTING
//     safety gate, not a second check at ask time. Ctrl-C aborts the turn.
//   - A clarification is not a command step: it does not consume max_steps.
//
// Code mapping:
//   AVAILABLE_TOOLS + ask_user       <-> tools.TOOL_SCHEMAS (run_command, ask_user, answer)
//   ask_user branch / loop           <-> controller._handle_ask_user + the run_turn loop
//   _prompt_user (numbered options)  <-> controller._prompt_user
//   MAX_CLARIFICATIONS               <-> controller.MAX_CLARIFICATIONS = 2
//   K (history window)               <-> context.HISTORY_TURNS = 10
//   env.user_request[@t]             <-> context._replay_turn: turn["request"]
//   resp.tool_call[@t.i] / .command  <-> turn["steps"][i]["tool"] / ["args"]["command"]
//   resp.question[@t.i]              <-> steps[i]["args"]["question"] ("(asked) ...")
//   env.user_reply[@t.i]             <-> steps[i]["reply"] ("(answered) ..." | "(no answer)")
//   sys.ran[@t.i]                    <-> steps[i]["rc"] is not None
//   sys.tool_response[@t.i]          <-> steps[i]["stdout"/"stderr"/"rc"]
//   sys.blocked_reason[@t.i]         <-> steps[i]["blocked_reason"]
//   resp.final_answer[@t]            <-> turn["final_answer"]
//   reply fed back as tool result    <-> controller._append_tool_result (T: native / U: prompted)

DoitAgentV5Clarify[@T, I]: {
    S: {
        AGENT_INSTRUCTIONS        // role, command style, safety + chit-chat + WHEN-TO-ASK policy
        AVAILABLE_TOOLS           // run_command(command, is_destructive, explanation),
                                  // ask_user(question, options?), answer(text)
                                  // NOTE: with the native adapter these schemas travel
                                  // out-of-band via the API tools= parameter, not as S: prose;
                                  // shown here to document their content (contrast v3_prompted)
    }
    U: {
        env.cwd[@T]
        env.datetime[@T]
        env.shell                 // constant per machine — no time index
        env.os
    }

    // --- replay the last K turns of THIS session as chat (unchanged from v4) ---
    // K = context.HISTORY_TURNS = 10; only the last K turns are actually replayed.
    ForEach(@t: range(1, @T-1)) {
        U: env.user_request[@t]
        ForEach(@i: range(1, @t.substeps)) {
            If resp.tool_call[@t.i] == ask_user {
                A: resp.question[@t.i]                      // "(asked) <question>"
                U: env.user_reply[@t.i]                     // "(answered) <reply>" | "(no answer)"
            }
            ElseIf sys.ran[@t.i] {
                A: resp.tool_call[@t.i].command             // "$ <command>"
                U: truncate(sys.tool_response[@t.i])        // COLD budget: exit code + stdout/stderr
            }
            Else {
                A: sys.blocked_reason[@t.i]                 // "(did not run — <reason>): <command>"
            }
        }
        If resp.final_answer[@t] {
            A: resp.final_answer[@t]
        }
    }

    // --- the current turn: now a real multi-step loop over I ---
    U: env.user_request[@T]
    ForEach(@i: range(1, I)) {                              // steps taken so far this turn
        A: resp.tool_call[@T.i]                             // run_command | ask_user | answer

        If resp.tool_call[@T.i] == ask_user {
            If sys.clarifications[@T.i] >= 2 {              // MAX_CLARIFICATIONS cap
                T: sys.clarification_capped                 // "limit reached — commit to best guess"
            }
            ElseIf env.user_reply[@T.i] == empty {
                T: sys.no_answer_default                    // "no answer — use your stated default"
            }
            Else {
                T: env.user_reply[@T.i]                     // "The user answered: <reply>"
                                                            // origin env (the USER typed it);
                                                            // role T: because it is packaged as
                                                            // the ask_user tool's result (§9.2)
            }
            // loop continues: re-call the LPU with the reply appended
        }

        ElseIf resp.tool_call[@T.i] == run_command {
            If sys.safety_check[@T.i].is_sudo            { T: sys.blocked[@T.i] }
            ElseIf sys.safety_check[@T.i].is_interactive { T: sys.blocked[@T.i] }
            ElseIf sys.safety_check[@T.i].is_destructive {
                If sys.confirmed[@T.i] {
                    T: truncate(sys.tool_response[@T.i])    // HOT budget
                }
                Else {
                    T: sys.blocked[@T.i]                    // declined / empty-on-destructive
                }
            }
            Else { T: truncate(sys.tool_response[@T.i]) }   // read-only, runs immediately
            // single-command mode: command_steps == max_steps ends the turn
        }

        // answer ends the turn (the finish signal).
    }
}
