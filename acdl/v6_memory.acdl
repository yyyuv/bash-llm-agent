// doit v6 — persistent memory (Phase 6)
// Builds on v5 (clarifications + within-turn loop). Two new things:
//   1. two new tools, remember(fact) and forget(id), and
//   2. a new CONTEXT element: sys.memories — a labeled block of ALL stored
//      facts about the user, injected on EVERY turn (Decision 9, option a:
//      no relevance filtering; embedding-based top-k is future work / a
//      possible Phase 9 extension). Each fact carries a visible [id] so the
//      model can forget/replace a specific one.
//
// Like ask_user, a memory op is a WITHIN-TURN step, not a command step: it
// applies the change to the shared store, feeds the result back, and the
// loop re-calls the LPU. So the model can remember AND run a command (or
// answer) in one turn — the "move here, and this is my project folder"
// dual-trigger case. Editing a fact = forget then remember across two steps.
//
// Design notes:
//   - Memories are NOT keyed by session (unlike env.history): a fact stated
//     in one terminal must be visible in all of them, so memories.json is a
//     single shared list. That is why sys.memories sits with the ambient S/U
//     setup, not inside the per-session ForEach(@t) history loop.
//   - The visible [id] is load-bearing: without it the model cannot name
//     which fact to forget. This is the whole reason ids are injected.
//   - A memory op does not consume max_steps; MAX_MEMORY_OPS is only
//     loop-guard headroom (a ceiling on iterations, not an anti-nag policy).
//
// Code mapping:
//   AVAILABLE_TOOLS + remember/forget <-> tools.TOOL_SCHEMAS (now 5 tools)
//   sys.memories block                <-> context.memory_block (+ prompts/memory_block.txt)
//   memory store                      <-> state.load_memories / add_memory / forget_memory
//   remember/forget branch            <-> controller._handle_memory + the run_turn loop
//   result fed back as tool result    <-> controller._append_tool_result (T: native / U: prompted)
//   everything else                   <-> unchanged from v5
//
// Context-only reminder (same convention as v2/v5): every If/ElseIf below
// tests controller-only state (sys.tool_call, sys.clarifications, the id
// lookup inside remember/forget) — that state is never itself sent to the
// model. Only the S:/U:/A:/T: lines are real messages in the context; the
// branches just select WHICH message gets emitted.

DoitAgentMemory[@T, I]: {
    S: {AGENT_INSTRUCTIONS        
        SAFTY_INSTRUCTIONS
        CLARIFICATION_INSTRUCTIONS
        MEMORY_INSTRUCTIONS
        AVAILABLE_TOOLS           // + remember(fact), forget(id)
    }
    U: {
    ENV_INFO(env.cwd[@T], env.datetime[@T], env.shell[@T], env.os[@T])
  }

  
    U: {
        MEMORY_HEADER                                  // "Known facts about the user ..."
        sys.memories
    }

    // replay the last K turns of this session as chat
    ForEach(@t: range(1, @T-1)) {
        U: env.history[@t].request
        ForEach(@i: env.history[@t].steps) {
            If env.history[@t].steps[@i].tool == ask_user {
                A: env.history[@t].steps[@i].question       // "(asked) <question>"
                U: env.history[@t].steps[@i].reply          // "(answered) <reply>" | "(no answer)"
            }
            ElseIf env.history[@t].steps[@i].ran {
                A: env.history[@t].steps[@i].command        
                U: truncate(env.history[@t].steps[@i].output)   
            }
            Else {
                A: env.history[@t].steps[@i].blocked        // "(did not run — <reason>): <command>"
            }
            
            }
        If env.history[@t].final_answer {
            A: env.history[@t].final_answer
        }
    }

    // Current turn: a multi-step loop over steps taken
        U: env.user_request[@T]
    ForEach(@i: range(1, I)) {                              // steps taken so far this turn
        A: sys.tool_call[@T.i]                             
        // (the model's own decision, replayed as context)
        If sys.tool_call[@T.i] == ask_user {
            If sys.clarifications >= MAX_CLARIFICATIONS {
                T: sys.clarification_capped                 // "limit reached — commit to best guess"
            }
            ElseIf sys.user_reply[@T.i] == empty {
                T: sys.no_answer_default                    // "no answer — use your stated default"
            }
            Else {
                T: sys.user_reply[@T.i]                     // "The user answered: <reply>"
            }
            // loop continues: re-call the LPU with the reply appended
        }

        ElseIf sys.tool_call[@T.i] == remember {
            T: sys.memory_stored[@T.i]                      // "Stored as memory <id>: <fact>"
        }

        ElseIf sys.tool_call[@T.i] == forget {
            T: sys.memory_forgotten[@T.i]                   // "Forgot memory <id>." | "no such id"
        }

        ElseIf sys.tool_call[@T.i] == run_command {
            If sys.safety_check.is_sudo        { T: sys.blocked }
            ElseIf sys.safety_check.is_interactive { T: sys.blocked }
            ElseIf sys.safety_check.is_destructive {
                If sys.confirmed {
                    T: truncate(sys.tool_response)             
                }
                Else {
                    T: sys.blocked                            // declined / empty-on-destructive
                }
            }
            Else { T: truncate(sys.tool_response) }                   
        }
    }
}