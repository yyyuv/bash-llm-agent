// doit v2 — adds the safety/confirm branch (Phase 2)
// Same single-decision turn as v1, but a run_command decision now passes
// through a deterministic safety gate before anything executes.

DoitAgentSafety[@T.I]: {
  S: {
    AGENT_INSTRUCTIONS
    SAFTY_INSTRUCTIONS // Regex-based safety gate, confirm prompt
    AVAILABLE_TOOLS(run_command, answer)
  }
  U: {
    ENV_INFO(env.cwd[@T], env.datetime[@T], env.shell[@T], env.os[@T])
  }
  U: env.user_request[@T]
}