// doit v6.5 — change_dir (D1's cd-trap fix, Phase 6.5 — a blocker inserted
// ahead of Phase 7, not Phase 7 itself)
// Builds on v6 (memory). One new thing: the change_dir(path) tool.
//
// The cd trap (locked since Day 1, PLAN.md D1): a Python subprocess cannot
// change its parent shell's cwd. change_dir validates the target against
// the real filesystem and writes it to ~/.doit/cd_target_$DOIT_SESSION;
// the doit() shell function (shell/*_snippet.sh) reads that file AFTER
// this process exits and performs the real cd, then deletes the file.
//
// Like remember/forget/ask_user, change_dir is a WITHIN-TURN step — it
// does not consume max_steps, so "go there and list it" is change_dir
// then run_command in the same turn (S:AVAILABLE_TOOLS already documents
// "multiple tool calls may occur in one turn", PLAN.md §1).
//
// Design note surfaced by live testing: a run_command in the SAME turn as
// change_dir still executes in the OLD cwd — the real cd only happens
// after this whole process exits. The model must qualify a same-turn
// command with the resolved path explicitly (not assume it's "already
// there"). This didn't hold with a system-prompt paragraph alone; it only
// took effect once the instruction was folded into the change_dir tool
// RESULT itself (DECISIONS.md P6.5b) — same lesson as P5e: an exception
// must sit at the point of decision, not in a separate paragraph.
//
// Code mapping:
//   AVAILABLE_TOOLS + change_dir      <-> tools.TOOL_SCHEMAS (now 6 tools)
//   path validation                   <-> tools.resolve_change_dir
//   cd_target handoff file            <-> state.write_cd_target / cd_target_path
//   change_dir branch                 <-> controller._handle_change_dir + the run_turn loop
//   shell-side real cd                <-> shell/zshrc_snippet.sh, shell/bashrc_snippet.sh (doit() wrapper)
//   result fed back as tool result    <-> controller._append_tool_result (T: native / U: prompted)
//   everything else                   <-> unchanged from v6

DoitAgentV6_5ChangeDir[@T, I]: {
    S: {
        AGENT_INSTRUCTIONS        // role, safety, when-to-ask, when-to-remember
                                  //   + change_dir-vs-run_command's `cd` policy
                                  //   + same-turn-command-targets-resolved-path rule
        AVAILABLE_TOOLS           // run_command, ask_user, answer, remember, forget,
                                  // change_dir(path)   -- 6 tools now
    }
    U: {
        env.cwd
        env.datetime
        env.shell
        env.os
    }

    U: {
        MEMORY_HEADER
        ForEach(m: sys.memories) { sys.memory_line[m] }
    }

    // --- replay last K turns (unchanged from v6; change_dir steps recorded
    // in history but NOT replayed, same rationale as memory ops: the real
    // filesystem/cwd is the source of truth, not the transcript) ---
    ForEach(@t: range(1, @T-1)) {
        U: env.history[@t].request
        ForEach(@i: env.history[@t].steps) {
            If env.history[@t].steps[@i].tool == ask_user {
                A: env.history[@t].steps[@i].question
                U: env.history[@t].steps[@i].reply
            }
            ElseIf env.history[@t].steps[@i].ran {
                A: env.history[@t].steps[@i].command
                U: truncate(env.history[@t].steps[@i].output)
            }
            Else {
                A: env.history[@t].steps[@i].blocked
            }
        }
        If env.history[@t].final_answer { A: env.history[@t].final_answer }
    }

    // --- the current turn ---
    U: env.user_request[@T]
    ForEach(@i: range(1, I)) {
        A: sys.tool_call[@T.i]                    // ... | change_dir

        If sys.tool_call[@T.i] == change_dir {
            If sys.resolved_path.is_dir {
                T: sys.cd_target_written[@T.i]     // "will change to <path> once doit exits;
                                                    //  NOT yet — qualify a same-turn command"
            } Else {
                T: sys.no_such_directory[@T.i]
            }
            // within-turn step: does NOT consume max_steps; loop continues
        }

        ElseIf sys.tool_call[@T.i] == run_command {
            // unchanged safety-gate branch from v6
        }
        // answer ends the turn.
    }
}
