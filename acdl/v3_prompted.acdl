// doit v3 — the PROMPTED adapter (Phase 3, model flexibility)
// Same agent, same tools, same safety gate as v2 — only the plumbing to
// the LPU differs, for local models without tool-calling.

DoitAgentPrompted[@T.I]: {
  //This agents assumes no inherent tool use capabilities
  S: {
    AGENT_INSTRUCTIONS
    SAFTY_INSTRUCTIONS
    AVAILABLE_TOOLS_TEXT
    JSON_PROTOCOL_INSTRUCTIONS
  }
  U: {
    ENV_INFO(env.cwd[@T], env.datetime[@T], env.shell[@T], env.os[@T])
  }
  U: env.user_request[@T]
}
